<layer-spec xmlns="urn:jboss:galleon:layer-spec:2.0" name="mcp-stdio-client">
    <dependencies>
        <layer name="ai"/>
    </dependencies>
    <feature spec="subsystem.ai">
        <feature spec="subsystem.ai.mcp-tool-provider">
            <param name="mcp-tool-provider" value="mcp"/>
            <param name="mcp-clients" value="mcp-stdio"/>
        </feature>
        <feature spec="subsystem.ai.mcp-stdio-client">
            <param name="mcp-stdio-client" value="mcp-stdio"/>
        </feature>
    </feature>
</layer-spec>
